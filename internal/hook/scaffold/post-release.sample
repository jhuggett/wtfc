#!/bin/bash
# ──────────────────────────────────────────────────────────────────────────
# wtfc post-release hook (sample)
#
# Hooks let you turn the structured changelog.json into anything else:
# a markdown file, a Slack post, a deploy trigger, etc. wtfc owns the
# trigger; you own the logic.
#
# To enable this sample:
#   mv wtfc/hooks/post-release.sample wtfc/hooks/post-release
#   chmod +x wtfc/hooks/post-release
#
# Quick reference:
#   Stdin           — the release JSON (one entry from changelog.json).
#   Working dir     — your project root (parent of wtfc/).
#   Env vars        — WTFC_EVENT, WTFC_RELEASE_NAME, WTFC_PROJECT_ROOT,
#                     WTFC_DIR, WTFC_CHANGELOG_PATH, WTFC_PENDING_DIR.
#   Events          — post-release, post-unrelease.
#   Exit code       — 0 = ok. Non-zero exits wtfc with status 1; the
#                     release stays committed (changelog is authoritative).
#
# Full docs: see docs/hooks.md in the wtfc source repo.
#
# This sample prepends a markdown section to CHANGELOG.md at the project
# root each time a release is cut. Requires `jq`. Edit freely.
# ──────────────────────────────────────────────────────────────────────────

set -euo pipefail

if ! command -v jq >/dev/null 2>&1; then
  echo "post-release: jq not found; install jq or rewrite this hook" >&2
  exit 1
fi

CHANGELOG="$WTFC_PROJECT_ROOT/CHANGELOG.md"
PAYLOAD=$(cat)

NAME=$(jq -r '.name' <<<"$PAYLOAD")
DATE=$(jq -r '.released_at' <<<"$PAYLOAD" | cut -dT -f1)
NOTES=$(jq -r '.notes // empty' <<<"$PAYLOAD")

{
  echo "## $NAME — $DATE"
  echo ""
  if [ -n "$NOTES" ]; then
    echo "$NOTES"
    echo ""
  fi
  jq -r '
    .changes[]
    | "- " + (.summary // .id)
      + (if .type then " _(\(.type))_" else "" end)
  ' <<<"$PAYLOAD"
  echo ""
  if [ -f "$CHANGELOG" ]; then
    cat "$CHANGELOG"
  fi
} > "$CHANGELOG.tmp"

mv "$CHANGELOG.tmp" "$CHANGELOG"

echo "post-release: prepended $NAME to $CHANGELOG"
